# 复制为 .env 后填写（密码勿提交仓库）。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/MAIN_DB?schema=public"
# 与 schema.prisma 中 shadowDatabaseUrl 对应：空库，仅用于 prisma migrate dev 校验
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/feedgen_prisma_shadow?schema=public"

# 新闻 AI 分类 ML Sidecar（Python，内网 3010，勿对公网暴露）
ML_SERVICE_URL=http://127.0.0.1:3010
ML_SERVICE_TOKEN=your-internal-token
CLASSIFICATION_ENABLED=1

# 腾讯机器翻译 TMT（英文 Feed 标题/简介翻译为中文）
TENCENT_TMT_SECRET_ID=your-secret-id
TENCENT_TMT_SECRET_KEY=your-secret-key
TENCENT_TMT_REGION=ap-guangzhou
TRANSLATION_ENABLED=1
