#!/bin/bash
# FeedGen 项目管理 CLI
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
# 解析软链，避免 /xxx/bin/feedgen -> scripts/feedgen 时根目录算错
while [[ -L "$SCRIPT_PATH" ]]; do
  _link="$(readlink "$SCRIPT_PATH")"
  if [[ "$_link" != /* ]]; then
    SCRIPT_PATH="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)/$_link"
  else
    SCRIPT_PATH="$_link"
  fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
FEEDGEN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$FEEDGEN_ROOT/scripts/feedgen.env"
BACKEND_SVC="feedgen-backend"
FRONTEND_SVC="feedgen-frontend"
ML_SVC="feedgen-ml"

has_systemd() {
  command -v systemctl >/dev/null 2>&1 && [[ -d /etc/systemd/system ]]
}

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE"
  fi
  FEEDGEN_ROOT="${FEEDGEN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
  ENV_FILE="$FEEDGEN_ROOT/scripts/feedgen.env"
  BACKEND_PORT="${BACKEND_PORT:-3000}"
  FRONTEND_PORT="${FRONTEND_PORT:-3001}"
  FEEDGEN_MODE="${FEEDGEN_MODE:-dev}"
  ML_SERVICE_PORT="${ML_SERVICE_PORT:-3010}"
}

detect_node() {
  if [[ -n "${FEEDGEN_NODE:-}" && -x "$FEEDGEN_NODE" ]]; then
    echo "$FEEDGEN_NODE"
    return
  fi
  if command -v node >/dev/null 2>&1; then
    command -v node
    return
  fi
  local found
  found=$(find /root/.cursor-server/bin/linux-x64 /usr/local/bin /usr/bin -name node -type f 2>/dev/null | sort -r | head -1 || true)
  if [[ -n "$found" && -x "$found" ]]; then
    echo "$found"
    return
  fi
  echo ""
}

write_env() {
  local node_bin npm_bin
  local _root="${FEEDGEN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
  local _backend_port="${BACKEND_PORT:-3000}"
  local _frontend_port="${FRONTEND_PORT:-3001}"
  local _mode="${FEEDGEN_MODE:-dev}"
  local _pw="${PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH:-}"
  local _ml_venv="${KEYATTEN_VENV:-}"
  local _ml_port="${ML_SERVICE_PORT:-3010}"
  # 保留已有额外配置
  if [[ -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    _pw="${PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH:-$_pw}"
    _ml_venv="${KEYATTEN_VENV:-$_ml_venv}"
    _ml_port="${ML_SERVICE_PORT:-$_ml_port}"
    _backend_port="${BACKEND_PORT:-$_backend_port}"
    _frontend_port="${FRONTEND_PORT:-$_frontend_port}"
    _mode="${FEEDGEN_MODE:-$_mode}"
    _root="${FEEDGEN_ROOT:-$_root}"
  fi
  node_bin=$(detect_node)
  npm_bin="${FEEDGEN_NPM:-$(command -v npm 2>/dev/null || echo /usr/local/bin/npm)}"
  if [[ -z "$node_bin" ]]; then
    echo "错误: 未找到 Node.js，请设置 FEEDGEN_NODE 环境变量" >&2
    exit 1
  fi
  mkdir -p "$_root/scripts" "$_root/logs"
  ENV_FILE="$_root/scripts/feedgen.env"
  cat > "$ENV_FILE" <<EOF
# FeedGen 服务环境配置（由 feedgen setup 自动生成，可手动修改）
FEEDGEN_ROOT=$_root
FEEDGEN_NODE=$node_bin
FEEDGEN_NPM=$npm_bin
BACKEND_PORT=$_backend_port
FRONTEND_PORT=$_frontend_port
FEEDGEN_MODE=$_mode
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=$_pw
KEYATTEN_VENV=$_ml_venv
ML_SERVICE_PORT=$_ml_port
EOF
  echo "已写入配置: $ENV_FILE"
  echo "  Node: $node_bin ($("$node_bin" -v))"
}

service_cmd() {
  local action=$1 target=$2
  if ! has_systemd; then
    case "$target" in
      all)
        process_service_cmd "$action" backend
        process_service_cmd "$action" frontend
        ;;
      backend|back|api) process_service_cmd "$action" backend ;;
      frontend|front|web) process_service_cmd "$action" frontend ;;
      ml|ml-service|sidecar) ml_service_cmd "$action" ;;
      *)
        echo "未知目标: $target（可用: all, backend, frontend, ml）" >&2
        exit 1
        ;;
    esac
    return
  fi
  case "$target" in
    all)
      systemctl "$action" "$BACKEND_SVC" "$FRONTEND_SVC"
      ;;
    backend|back|api)
      systemctl "$action" "$BACKEND_SVC"
      ;;
    frontend|front|web)
      systemctl "$action" "$FRONTEND_SVC"
      ;;
    ml|ml-service|sidecar)
      if [[ -f /etc/systemd/system/${ML_SVC}.service ]]; then
        systemctl "$action" "$ML_SVC"
      else
        ml_service_cmd "$action"
      fi
      ;;
    *)
      echo "未知目标: $target（可用: all, backend, frontend, ml）" >&2
      exit 1
      ;;
  esac
}

process_service_cmd() {
  local action=$1
  local which=$2
  load_env
  local node_dir port workdir start_cmd label log_out log_err pid_file
  node_dir=$(dirname "$(detect_node)")
  mkdir -p "$FEEDGEN_ROOT/logs"
  export PATH="$node_dir:/usr/local/bin:/usr/bin:/usr/sbin:/bin:/sbin:$PATH"

  if [[ "$which" == "backend" ]]; then
    label="后端"
    port="$BACKEND_PORT"
    workdir="$FEEDGEN_ROOT/backend"
    start_cmd=("${FEEDGEN_NPM:-npm}" run dev)
    log_out="$FEEDGEN_ROOT/logs/backend.log"
    log_err="$FEEDGEN_ROOT/logs/backend.error.log"
    pid_file="$FEEDGEN_ROOT/logs/backend.pid"
  else
    label="前端"
    port="$FRONTEND_PORT"
    workdir="$FEEDGEN_ROOT/frontend"
    start_cmd=("$FEEDGEN_ROOT/frontend/node_modules/.bin/http-server" -p "$port" -c-1 .)
    log_out="$FEEDGEN_ROOT/logs/frontend.log"
    log_err="$FEEDGEN_ROOT/logs/frontend.error.log"
    pid_file="$FEEDGEN_ROOT/logs/frontend.pid"
  fi

  case "$action" in
    start)
      if lsof -ti:"$port" >/dev/null 2>&1; then
        echo "${label} already running on port ${port}"
        return 0
      fi
      if [[ -f "$FEEDGEN_ROOT/backend/.env" ]]; then
        set -a
        # shellcheck disable=SC1090
        source "$FEEDGEN_ROOT/backend/.env"
        set +a
      fi
      (
        cd "$workdir"
        nohup "${start_cmd[@]}" >>"$log_out" 2>>"$log_err" &
        echo $! >"$pid_file"
      )
      sleep 1
      if lsof -ti:"$port" >/dev/null 2>&1; then
        echo "${label} started (port ${port}, log ${log_out})"
      else
        echo "${label} starting (port ${port}; check ${log_err} if failed)"
      fi
      ;;
    stop)
      local pids
      pids=$(lsof -ti:"$port" 2>/dev/null || true)
      if [[ -n "$pids" ]]; then
        kill $pids 2>/dev/null || true
        sleep 1
        pids=$(lsof -ti:"$port" 2>/dev/null || true)
        [[ -n "$pids" ]] && kill -9 $pids 2>/dev/null || true
      fi
      if [[ "$which" == "backend" ]]; then
        pkill -f "nodemon src/index.ts" 2>/dev/null || true
        pkill -f "ts-node.*src/index.ts" 2>/dev/null || true
      else
        pkill -f "http-server -p ${port}" 2>/dev/null || true
      fi
      rm -f "$pid_file"
      echo "${label} stopped"
      ;;
    restart)
      process_service_cmd stop "$which"
      sleep 1
      process_service_cmd start "$which"
      ;;
    enable|disable)
      echo "systemd unavailable; use feedgen start/stop instead of ${action}" >&2
      ;;
    *)
      echo "unknown action: $action" >&2
      exit 1
      ;;
  esac
}

ml_service_cmd() {
  local action=$1
  load_env
  local port="${ML_SERVICE_PORT:-3010}"
  local run_sh="$FEEDGEN_ROOT/ml-service/run.sh"
  local log_file="$FEEDGEN_ROOT/logs/ml-service.log"
  local pid_file="$FEEDGEN_ROOT/logs/ml-service.pid"

  case "$action" in
    start)
      if [[ ! -f "$FEEDGEN_ROOT/backend/.env" ]]; then
        echo "error: missing backend/.env (need ML_SERVICE_TOKEN)" >&2
        exit 1
      fi
      # shellcheck disable=SC1090
      set -a && source "$FEEDGEN_ROOT/backend/.env" && set +a
      if [[ -z "${ML_SERVICE_TOKEN:-}" ]]; then
        echo "error: ML_SERVICE_TOKEN not set in backend/.env" >&2
        exit 1
      fi
      mkdir -p "$FEEDGEN_ROOT/logs"
      if lsof -ti:"$port" >/dev/null 2>&1; then
        echo "ML already running on port ${port}"
        return 0
      fi
      # run.sh 依赖 KEYATTEN_VENV；保证本机 conda 环境生效
      export KEYATTEN_VENV="${KEYATTEN_VENV:-/Volumes/SSD4T/dev/feedgen-ml}"
      nohup bash "$run_sh" >>"$log_file" 2>&1 &
      echo $! >"$pid_file"
      echo "ML started (PID $(cat "$pid_file"), log ${log_file})"
      ;;
    stop)
      local pids
      pids=$(lsof -ti:"$port" 2>/dev/null || true)
      if [[ -n "$pids" ]]; then
        kill $pids 2>/dev/null || true
        sleep 1
        pids=$(lsof -ti:"$port" 2>/dev/null || true)
        [[ -n "$pids" ]] && kill -9 $pids 2>/dev/null || true
      fi
      pkill -f "uvicorn app.main:app" 2>/dev/null || true
      rm -f "$pid_file"
      echo "ML stopped"
      ;;
    restart)
      ml_service_cmd stop
      sleep 1
      ml_service_cmd start
      ;;
    *)
      echo "unknown ML action: $action" >&2
      exit 1
      ;;
  esac
}

check_ml_health() {
  local port=$1
  curl -s --connect-timeout 2 "http://127.0.0.1:${port}/internal/health" 2>/dev/null \
    | grep -q '"status"' && echo "ok" || echo "fail"
}

check_http() {
  local port=$1
  curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 "http://127.0.0.1:${port}/" 2>/dev/null || echo "000"
}

show_status() {
  load_env
  echo "========== FeedGen 服务状态 =========="
  echo "项目目录: $FEEDGEN_ROOT"
  echo "运行模式: $FEEDGEN_MODE"
  echo "进程管理: $(has_systemd && echo systemd || echo process)"
  echo ""
  for svc in "$BACKEND_SVC" "$FRONTEND_SVC"; do
    local label port
    if [[ "$svc" == "$BACKEND_SVC" ]]; then
      label="后端"
      port=$BACKEND_PORT
    else
      label="前端"
      port=$FRONTEND_PORT
    fi
    local active http_code
    if has_systemd; then
      active=$(systemctl is-active "$svc" 2>/dev/null || echo "unknown")
    elif lsof -ti:"$port" >/dev/null 2>&1; then
      active="running"
    else
      active="inactive"
    fi
    http_code=$(check_http "$port")
    printf "  %-6s  state=%-10s  端口=%-5s  HTTP=%s  http://127.0.0.1:%s\n" \
      "$label" "$active" "$port" "$http_code" "$port"
  done
  local ml_active ml_health ml_port
  ml_port="${ML_SERVICE_PORT:-3010}"
  if has_systemd && [[ -f /etc/systemd/system/${ML_SVC}.service ]]; then
    ml_active=$(systemctl is-active "$ML_SVC" 2>/dev/null || echo "unknown")
  elif lsof -ti:"$ml_port" >/dev/null 2>&1; then
    ml_active="running"
  else
    ml_active="inactive"
  fi
  ml_health=$(check_ml_health "$ml_port")
  printf "  %-6s  state=%-10s  端口=%-5s  health=%s  http://127.0.0.1:%s/internal/health\n" \
    "ML" "$ml_active" "$ml_port" "$ml_health" "$ml_port"
  echo ""
  if has_systemd; then
    local be fe ml_en
    be=$(systemctl is-enabled "$BACKEND_SVC" 2>/dev/null) || be="disabled"
    fe=$(systemctl is-enabled "$FRONTEND_SVC" 2>/dev/null) || fe="disabled"
    ml_en=$(systemctl is-enabled "$ML_SVC" 2>/dev/null) || ml_en="disabled"
    echo "  后端开机自启: $be"
    echo "  前端开机自启: $fe"
    echo "  ML 开机自启: $ml_en"
  else
    echo "  开机自启: 当前环境无 systemd（请用 start-infra / feedgen start）"
  fi
  echo "======================================"
}

show_logs() {
  load_env
  local target=${1:-all}
  local follow=${2:-}
  if has_systemd; then
    local args=()
    [[ "$follow" == "-f" ]] && args=(-f)
    case "$target" in
      all)     journalctl -u "$BACKEND_SVC" -u "$FRONTEND_SVC" "${args[@]}" -n 50 ;;
      backend|back|api) journalctl -u "$BACKEND_SVC" "${args[@]}" -n 100 ;;
      frontend|front|web) journalctl -u "$FRONTEND_SVC" "${args[@]}" -n 100 ;;
      ml|ml-service|sidecar)
        if systemctl is-active "$ML_SVC" >/dev/null 2>&1; then
          journalctl -u "$ML_SVC" "${args[@]}" -n 100
        elif [[ -f "$FEEDGEN_ROOT/logs/ml-service.log" ]]; then
          if [[ "$follow" == "-f" ]]; then
            tail -f "$FEEDGEN_ROOT/logs/ml-service.log"
          else
            tail -n 100 "$FEEDGEN_ROOT/logs/ml-service.log"
          fi
        else
          echo "ML 服务日志不可用（未安装 systemd 单元且 logs/ml-service.log 不存在）" >&2
          exit 1
        fi
        ;;
      *) echo "未知目标: $target（可用: all, backend, frontend, ml）" >&2; exit 1 ;;
    esac
    return
  fi

  local file
  case "$target" in
    all)
      if [[ "$follow" == "-f" ]]; then
        tail -f "$FEEDGEN_ROOT/logs/backend.log" "$FEEDGEN_ROOT/logs/backend.error.log" \
          "$FEEDGEN_ROOT/logs/frontend.log" "$FEEDGEN_ROOT/logs/frontend.error.log"
      else
        echo "----- backend -----"
        tail -n 50 "$FEEDGEN_ROOT/logs/backend.log" 2>/dev/null || true
        tail -n 50 "$FEEDGEN_ROOT/logs/backend.error.log" 2>/dev/null || true
        echo "----- frontend -----"
        tail -n 50 "$FEEDGEN_ROOT/logs/frontend.log" 2>/dev/null || true
        tail -n 50 "$FEEDGEN_ROOT/logs/frontend.error.log" 2>/dev/null || true
      fi
      ;;
    backend|back|api)
      file="$FEEDGEN_ROOT/logs/backend"
      if [[ "$follow" == "-f" ]]; then
        tail -f "${file}.log" "${file}.error.log"
      else
        tail -n 100 "${file}.log" 2>/dev/null || true
        tail -n 100 "${file}.error.log" 2>/dev/null || true
      fi
      ;;
    frontend|front|web)
      file="$FEEDGEN_ROOT/logs/frontend"
      if [[ "$follow" == "-f" ]]; then
        tail -f "${file}.log" "${file}.error.log"
      else
        tail -n 100 "${file}.log" 2>/dev/null || true
        tail -n 100 "${file}.error.log" 2>/dev/null || true
      fi
      ;;
    ml|ml-service|sidecar)
      if [[ -f "$FEEDGEN_ROOT/logs/ml-service.log" ]]; then
        if [[ "$follow" == "-f" ]]; then
          tail -f "$FEEDGEN_ROOT/logs/ml-service.log"
        else
          tail -n 100 "$FEEDGEN_ROOT/logs/ml-service.log"
        fi
      else
        echo "ML 服务日志不存在: $FEEDGEN_ROOT/logs/ml-service.log" >&2
        exit 1
      fi
      ;;
    *) echo "未知目标: $target（可用: all, backend, frontend, ml）" >&2; exit 1 ;;
  esac
}

show_info() {
  load_env
  echo "FeedGen 项目信息"
  echo "  前端: http://127.0.0.1:${FRONTEND_PORT}"
  echo "  后端: http://127.0.0.1:${BACKEND_PORT}"
  echo "  API:  http://127.0.0.1:${BACKEND_PORT}/api"
  echo "  配置: $FEEDGEN_ROOT/frontend/config.js"
  echo "  环境: $FEEDGEN_ROOT/backend/.env"
  echo "  ML:   http://127.0.0.1:${ML_SERVICE_PORT:-3010}/internal/health"
  echo "  日志: $FEEDGEN_ROOT/logs/ 及 journalctl -u feedgen-backend|feedgen-frontend|feedgen-ml"
}

run_install() {
  load_env
  local node_dir
  node_dir=$(dirname "$(detect_node)")
  export PATH="$node_dir:/usr/local/bin:/usr/bin:$PATH"
  echo ">>> 安装后端依赖..."
  (cd "$FEEDGEN_ROOT/backend" && npm install && npx prisma generate)
  echo ">>> 安装前端依赖..."
  (cd "$FEEDGEN_ROOT/frontend" && npm install)
  echo "依赖安装完成"
}

run_build() {
  load_env
  local node_dir
  node_dir=$(dirname "$(detect_node)")
  export PATH="$node_dir:/usr/local/bin:/usr/bin:$PATH"
  echo ">>> 编译后端..."
  (cd "$FEEDGEN_ROOT/backend" && npm run build)
  echo "编译完成: backend/dist/"
}

run_setup() {
  write_env
  if has_systemd; then
    install_systemd
    systemctl daemon-reload
  else
    mkdir -p "$FEEDGEN_ROOT/logs"
    echo "当前环境无 systemd，已跳过单元安装（将使用进程模式启停）"
  fi
  # 尽量安装到 PATH
  local dest=""
  if [[ -w /usr/local/bin ]]; then
    dest=/usr/local/bin/feedgen
  elif [[ -d /Volumes/SSD4T/dev/bin ]]; then
    mkdir -p /Volumes/SSD4T/dev/bin
    dest=/Volumes/SSD4T/dev/bin/feedgen
  else
    mkdir -p "$HOME/bin"
    dest="$HOME/bin/feedgen"
  fi
  ln -sfn "$FEEDGEN_ROOT/scripts/feedgen" "$dest"
  chmod +x "$FEEDGEN_ROOT/scripts/feedgen"
  echo "已安装 CLI: $dest -> $FEEDGEN_ROOT/scripts/feedgen"
  echo ""
  echo "初始化完成。常用命令:"
  echo "  feedgen start          # 启动前后端"
  echo "  feedgen stop           # 停止前后端"
  echo "  feedgen status         # 查看状态"
  if has_systemd; then
    echo "  feedgen enable         # 开机自启"
  fi
}

install_systemd() {
  load_env
  local node_dir="${FEEDGEN_NODE%/*}"
  local _root="$FEEDGEN_ROOT"
  local _env="$ENV_FILE"
  local _npm="$FEEDGEN_NPM"
  local _backend_port="$BACKEND_PORT"
  local _frontend_port="$FRONTEND_PORT"
  cat > /etc/systemd/system/feedgen-backend.service <<EOF
[Unit]
Description=FeedGen Backend API Server
After=network.target postgresql-14.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=${_root}/backend
EnvironmentFile=${_env}
EnvironmentFile=-${_root}/backend/.env
Environment=PATH=${node_dir}:/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=development
ExecStart=${_npm} run dev
ExecStop=/bin/bash -c 'pids=\$(lsof -ti:${_backend_port} 2>/dev/null); [ -n "\$pids" ] && kill -9 \$pids; pkill -f "nodemon src/index.ts" || true'
Restart=on-failure
RestartSec=5
StandardOutput=append:${_root}/logs/backend.log
StandardError=append:${_root}/logs/backend.error.log

[Install]
WantedBy=multi-user.target
EOF

  cat > /etc/systemd/system/feedgen-frontend.service <<EOF
[Unit]
Description=FeedGen Frontend Static Server
After=network.target feedgen-backend.service

[Service]
Type=simple
WorkingDirectory=${_root}/frontend
EnvironmentFile=${_env}
EnvironmentFile=-${_root}/backend/.env
Environment=PATH=${node_dir}:/usr/local/bin:/usr/bin:/bin
ExecStart=${_root}/frontend/node_modules/.bin/http-server -p ${_frontend_port} -c-1 .
ExecStop=/bin/bash -c 'pids=\$(lsof -ti:${_frontend_port} 2>/dev/null); [ -n "\$pids" ] && kill -9 \$pids || true'
Restart=on-failure
RestartSec=5
StandardOutput=append:${_root}/logs/frontend.log
StandardError=append:${_root}/logs/frontend.error.log

[Install]
WantedBy=multi-user.target
EOF
  cat > /etc/systemd/system/feedgen-ml.service <<EOF
[Unit]
Description=FeedGen ML Classification Sidecar
After=network.target

[Service]
Type=simple
WorkingDirectory=${_root}/ml-service
EnvironmentFile=-${_root}/backend/.env
Environment=ML_SERVICE_PORT=${ML_SERVICE_PORT:-3010}
Environment=ML_MODELS_DIR=${_root}/ml-service/models
Environment=KEYATTEN_VENV=/www/wwwroot/keyatten/miniconda
ExecStart=/bin/bash ${_root}/ml-service/run.sh
ExecStop=/bin/bash -c 'pids=\$(lsof -ti:${ML_SERVICE_PORT:-3010} 2>/dev/null); [ -n "\$pids" ] && kill \$pids; pkill -f "uvicorn app.main:app" || true'
Restart=on-failure
RestartSec=5
StandardOutput=append:${_root}/logs/ml-service.log
StandardError=append:${_root}/logs/ml-service.error.log

[Install]
WantedBy=multi-user.target
EOF
  echo "已安装 systemd 单元: feedgen-backend, feedgen-frontend, feedgen-ml"
}

run_playwright() {
  load_env
  local chrome="/root/.cache/ms-playwright-old/chromium-1033/chrome-linux/chrome"
  local node_dir
  node_dir=$(dirname "$(detect_node)")

  echo ">>> CentOS 7 不支持官方 npx playwright install（需 glibc 2.18+ 及 Ubuntu 24 依赖库）"
  echo ">>> 本项目使用兼容版 Chromium 108，无需安装最新 Playwright 浏览器"
  echo ""

  # Playwright 截图/渲染中文页面需要系统中文字体，否则中文显示为方块
  if ! fc-list :lang=zh 2>/dev/null | grep -q .; then
    echo ">>> 未检测到中文字体，正在安装 Noto CJK 与文泉驿微米黑..."
    if command -v yum >/dev/null 2>&1; then
      yum install -y google-noto-sans-cjk-fonts wqy-microhei-fonts >/dev/null 2>&1 \
        && fc-cache -fv >/dev/null 2>&1 \
        && echo "✓ 中文字体已安装" \
        || echo "警告: 中文字体安装失败，Playwright 截图中文可能显示为方块" >&2
    else
      echo "警告: 未找到 yum，请手动安装中文字体（如 google-noto-sans-cjk-fonts）" >&2
    fi
  else
    echo "✓ 中文字体: $(fc-list :lang=zh 2>/dev/null | head -1 | cut -d: -f2 | xargs)"
  fi
  echo ""

  if [[ -x "$chrome" ]]; then
    echo "✓ 兼容版 Chromium 已存在: $chrome"
    "$chrome" --version 2>/dev/null || true
  else
    echo ">>> 正在下载兼容版 Chromium（Playwright 1.28 / Chromium 108）..."
    export http_proxy="${http_proxy:-http://127.0.0.1:7890}"
    export https_proxy="${https_proxy:-http://127.0.0.1:7890}"
    local tmp=/tmp/feedgen-pw-install
    rm -rf "$tmp" && mkdir -p "$tmp"
    (cd "$tmp" && npm init -y >/dev/null 2>&1 && npm install playwright@1.28.1 --no-save >/dev/null 2>&1)
    PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright-old \
      "$tmp/node_modules/.bin/playwright" install chromium
    rm -rf "$tmp"
    if [[ ! -x "$chrome" ]]; then
      echo "错误: Chromium 下载失败" >&2
      exit 1
    fi
    echo "✓ 下载完成: $chrome"
  fi

  echo ""
  echo ">>> 验证浏览器启动..."
  PATH="$node_dir:/usr/local/bin:/usr/bin:$PATH" \
    PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="$chrome" \
    "$node_dir/node" -e "
const { chromium } = require('$FEEDGEN_ROOT/backend/node_modules/playwright');
(async () => {
  const browser = await chromium.launch({
    headless: true,
    executablePath: '$chrome',
    args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-dev-shm-usage'],
  });
  const page = await browser.newPage();
  await page.goto('https://example.com', { timeout: 15000 });
  console.log('OK:', await page.title());
  await browser.close();
})().catch((e) => { console.error('FAIL:', e.message.split('\\n')[0]); process.exit(1); });
" 2>&1
  echo ""
  echo "配置路径: backend/.env 与 scripts/feedgen.env 中的 PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH"
}

usage() {
  cat <<'EOF'
FeedGen 项目管理工具

用法: feedgen <命令> [目标]

服务管理:
  start   [all|backend|frontend|ml]   启动服务（默认 all，不含 ml）
  stop    [all|backend|frontend|ml]   停止服务（默认 all，不含 ml）
  restart [all|backend|frontend|ml]   重启服务（默认 all，不含 ml）
  status                            查看运行状态（含 ML health）
  logs    [all|backend|frontend|ml] [-f]  查看日志（-f 实时跟踪）
  enable  [all|backend|frontend|ml]   设置开机自启（默认 all，不含 ml）
  disable [all|backend|frontend|ml]   取消开机自启（默认 all，不含 ml）

项目维护:
  setup       初始化配置与 systemd 服务
  install     安装前后端 npm 依赖
  build       编译后端 TypeScript
  playwright  检查/安装 CentOS7 兼容版 Chromium（勿用 npx playwright install）
  info        显示访问地址与配置路径

示例:
  feedgen start
  feedgen restart backend
  feedgen restart ml
  feedgen logs backend -f
  feedgen logs ml -f
  feedgen playwright
  feedgen enable
EOF
}

main() {
  local cmd=${1:-}
  local arg=${2:-all}
  local arg2=${3:-}

  case "$cmd" in
    start)   service_cmd start "$arg" ;;
    stop)    service_cmd stop "$arg" ;;
    restart) service_cmd restart "$arg" ;;
    status)  show_status ;;
    logs)    show_logs "$arg" "$arg2" ;;
    enable)  service_cmd enable "$arg" ;;
    disable) service_cmd disable "$arg" ;;
    setup)   run_setup ;;
    install) run_install ;;
    build)   run_build ;;
    playwright|pw) run_playwright ;;
    info)    show_info ;;
    help|-h|--help|"") usage ;;
    *)
      echo "未知命令: $cmd" >&2
      usage
      exit 1
      ;;
  esac
}

main "$@"
